{
    "editor.fontSize": 14.5,
    "editor.lineNumbers": "relative",
    "window.density.editorTabHeight": "compact",
    "notebook.lineNumbers": "on",
    "vim.overrideCopy": false,
    "vim.useSystemClipboard": true,
    "vim.leader": "<space>",
    "vim.normalModeKeyBindings": [
        {
            "before": ["<leader>", "f"],
            "commands": ["workbench.action.quickOpen"]
        },
        {
            "before": ["<leader>", "w"],
            "commands": [":w"]
        },
        {
            "before": ["<leader>", "q"],
            "commands": [":q"]
        },
        {
            "before": ["<leader>", "e"],
            "commands": ["workbench.action.toggleSidebarVisibility"]
        },
        {
            "before": ["<leader>", "t"],
            "commands": ["workbench.action.terminal.toggleTerminal"]
        },
        {
            "before": ["<leader>", "v", "s"],
            "commands": [
                "workbench.action.splitEditorRight",
                "workbench.action.quickOpen"
            ]
        },
        {
            "before": ["<leader>", "v", "v"],
            "commands": ["workbench.action.navigateEditorGroups"]
        },
        {
            "before": ["<leader>", "a"],
            "commands": ["workbench.action.toggleAuxiliaryBar"]
        },
        {
            "before": ["<leader>", "s"],
            "commands": ["workbench.action.previousEditor"]
        },
        {
            "before": ["<leader>", "g"],
            "commands": ["workbench.action.nextEditor"]
        },
    ],
    "go.toolsEnvVars": {
        "CGO_CFLAGS": "-I/opt/homebrew/opt/libraw/include -I/opt/homebrew/opt/jpeg-turbo/include",
        "CGO_LDFLAGS": "-L/opt/homebrew/opt/libraw/lib -L/opt/homebrew/opt/jpeg-turbo/lib"
    },
    "workbench.colorTheme": "Gruvbox Dark Hard",
    "cursor.composer.usageSummaryDisplay": "always",
}
